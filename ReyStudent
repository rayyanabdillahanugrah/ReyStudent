        <label class="form-label">Judul</label>
        <input class="form-input" id="snJudul" placeholder="Judul catatan">
      </div>
      <div class="form-group">
        <label class="form-label">Isi</label>
        <textarea class="form-textarea" id="snIsi" rows="5" placeholder="Tulis catatan di sini..."></textarea>
      </div>
    </div>
