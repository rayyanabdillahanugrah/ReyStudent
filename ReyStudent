<div class="toast-wrap" id="toastWrap"></div>

<script>
const DAYS = ['Senin','Selasa','Rabu','Kamis','Jumat','Sabtu','Minggu'];

const st = {
  view: 'schedule',
  day: null,
  subjectId: null,
  detailView: 'tugas',
  editSubjectId: null,
  editTaskId: null,
  editNoteId: null,
  editSnId: null,
};

let pendingFiles = [];

const get  = k => { try { return JSON.parse(localStorage.getItem('rm_'+k)) || null; } catch { return null; } };
const set  = (k,v) => localStorage.setItem('rm_'+k, JSON.stringify(v));
const uid  = () => Date.now().toString(36) + Math.random().toString(36).slice(2,6);
const esc  = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');

const getSchedule = () => get('schedule') || {};
const setSchedule = d => set('schedule', d);
const getTasks    = () => get('tasks') || {};
const setTasks    = d => set('tasks', d);
const getNotes    = () => get('notes') || {};
const setNotes    = d => set('notes', d);
const getSN       = () => get('sn') || [];
const setSN       = d => set('sn', d);

function navigateTo(view, subjectId, day) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.toggle('active', n.dataset.view === view));

  const content = document.getElementById('mainContent');
  st.view = view;

  if (view === 'subject-detail') {
    st.subjectId = subjectId;
    st.day = day;
    content.classList.add('no-pad');
    document.getElementById('page-subject-detail').classList.add('active');
    closePanel();
    st.detailView = 'tugas';
    switchDetail('tugas');
  } else {
    content.classList.remove('no-pad');
    document.getElementById('page-'+view).classList.add('active');
    if (view === 'schedule') renderSchedule();
    if (view === 'catatan-khusus') renderSN();
  }

  setTopbar();
  closeSidebar();
}

function setTopbar() {
  const el = document.getElementById('topbarContent');
  if (st.view === 'schedule') {
    el.innerHTML = '<div class="topbar-title">Schedule</div>';
  } else if (st.view === 'catatan-khusus') {
    el.innerHTML = '<div class="topbar-title">Catatan Khusus</div>';
  } else {
    const sched = getSchedule();
    const subj = (sched[st.day]?.subjects || []).find(s => s.id === st.subjectId);
    el.innerHTML = `
      <div class="topbar-crumb">
        <button class="topbar-back" onclick="navigateTo('schedule')">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          Kembali
        </button>
        <span class="sep">/</span>
        <span>${esc(st.day)}</span>
        <span class="sep">/</span>
        <span class="cur">${esc(subj?.nama||'')}</span>
      </div>`;
  }
}

function renderSchedule() {
  const sched = getSchedule();
  document.getElementById('daysGrid').innerHTML = DAYS.map(day => {
    const d = sched[day] || { subjects:[], ekskul:null };
    const subs = d.subjects || [];
    const preview = subs.slice(0,3).map(s =>
      `<div class="day-preview-item"><div class="day-dot"></div>${esc(s.nama)}</div>`
    ).join('') + (subs.length>3 ? `<div class="day-preview-item" style="color:var(--text-muted)">+${subs.length-3} lainnya</div>` : '');
    return `<div class="day-card" onclick="openPanel('${day}')">
      <div class="day-card-header">
        <div class="day-name">${day}</div>
        <div class="day-count">${subs.length} mapel</div>
      </div>
      <div class="day-preview">
        ${subs.length ? preview : '<div class="day-empty">Belum ada mata pelajaran</div>'}
      </div>
      ${d.ekskul ? `<div class="day-ekskul-badge">${esc(d.ekskul.nama)}</div>` : ''}
    </div>`;
  }).join('');
}

function openPanel(day) {
  st.day = day;
  document.getElementById('panelTitle').textContent = day;
  document.getElementById('panelOverlay').classList.add('open');
  renderPanel();
}

function closePanel() {
  document.getElementById('panelOverlay').classList.remove('open');
}

function renderPanel() {
  const sched = getSchedule();
  const d = sched[st.day] || { subjects:[], ekskul:null };
  const subs = d.subjects || [];

  const EDIT_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
  const DEL_ICON  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;

  let html = `
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
      <div class="sub-label">MATA PELAJARAN</div>
      <button class="btn btn-primary btn-sm" onclick="openSubjectModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Tambah
      </button>
    </div>`;

  if (!subs.length) {
    html += `<div class="empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <p>Belum ada mata pelajaran<br>Tambah mapel untuk hari ini</p>
    </div>`;
  } else {
    subs.forEach(s => {
      html += `<div class="subject-card" onclick="navigateTo('subject-detail','${s.id}','${st.day}')">
        <div class="subject-card-top">
          <div class="subject-card-info">
            <div class="subject-nama">${esc(s.nama)}</div>
            <div class="subject-guru">${esc(s.guru)}</div>
            <div class="subject-time">${s.jamMulai||'--:--'} – ${s.jamSelesai||'--:--'}</div>
          </div>
          <div class="subject-actions" onclick="event.stopPropagation()">
            <button class="action-btn action-edit" onclick="openSubjectModal('${s.id}')" title="Edit">${EDIT_ICON}</button>
            <button class="action-btn action-delete" onclick="deleteSubject('${s.id}')" title="Hapus">${DEL_ICON}</button>
          </div>
        </div>
      </div>`;
    });
  }

  html += `<div class="ekskul-section">
    <div class="sub-label">EKSTRAKURIKULER</div>`;
  if (d.ekskul) {
    html += `<div class="ekskul-display">
      <span class="ekskul-name">${esc(d.ekskul.nama)}</span>
      <button class="btn btn-danger btn-sm" onclick="deleteEkskul()">Hapus</button>
    </div>`;
  } else {
    html += `<button class="btn btn-secondary btn-sm" onclick="openEkskulModal()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Ekskul
    </button>`;
  }
  html += `</div>`;

  document.getElementById('panelBody').innerHTML = html;
}

function openSubjectModal(editId) {
  st.editSubjectId = editId || null;
  document.getElementById('subjectModalTitle').textContent = editId ? 'Edit Mata Pelajaran' : 'Tambah Mata Pelajaran';
  if (editId) {
    const s = (getSchedule()[st.day]?.subjects || []).find(x => x.id === editId);
    if (s) {
      document.getElementById('sNama').value = s.nama;
      document.getElementById('sGuru').value = s.guru;
      document.getElementById('sJamMulai').value = s.jamMulai;
      document.getElementById('sJamSelesai').value = s.jamSelesai;
    }
  } else {
    ['sNama','sGuru','sJamMulai','sJamSelesai'].forEach(id => document.getElementById(id).value = '');
  }
  openModal('subjectModal');
}

function saveSubject() {
  const nama = document.getElementById('sNama').value.trim();
  const guru = document.getElementById('sGuru').value.trim();
  const jamMulai = document.getElementById('sJamMulai').value;
  const jamSelesai = document.getElementById('sJamSelesai').value;
  if (!nama) { toast('Nama mata pelajaran wajib diisi'); return; }

  const sched = getSchedule();
  if (!sched[st.day]) sched[st.day] = { subjects:[], ekskul:null };

  if (st.editSubjectId) {
    sched[st.day].subjects = sched[st.day].subjects.map(s =>
      s.id === st.editSubjectId ? {...s, nama, guru, jamMulai, jamSelesai} : s
    );
    toast('Mata pelajaran diperbarui');
  } else {
    sched[st.day].subjects.push({ id:uid(), nama, guru, jamMulai, jamSelesai });
    toast('Mata pelajaran ditambahkan');
  }

  setSchedule(sched);
  closeModal('subjectModal');
  renderPanel();
  renderSchedule();
  st.editSubjectId = null;
}

function deleteSubject(id) {
  if (!confirm('Hapus mata pelajaran ini beserta semua tugas dan catatannya?')) return;
  const sched = getSchedule();
  sched[st.day].subjects = sched[st.day].subjects.filter(s => s.id !== id);
  setSchedule(sched);
  const tasks = getTasks(); delete tasks[id]; setTasks(tasks);
  const notes = getNotes(); delete notes[id]; setNotes(notes);
  renderPanel();
  renderSchedule();
  toast('Mata pelajaran dihapus');
}

function openEkskulModal() {
  document.getElementById('ekskulNama').value = '';
  openModal('ekskulModal');
}

function saveEkskul() {
  const nama = document.getElementById('ekskulNama').value.trim();
  if (!nama) { toast('Nama ekskul wajib diisi'); return; }
  const sched = getSchedule();
  if (!sched[st.day]) sched[st.day] = { subjects:[], ekskul:null };
  sched[st.day].ekskul = { nama };
  setSchedule(sched);
  closeModal('ekskulModal');
  renderPanel();
  renderSchedule();
  toast('Ekskul ditambahkan');
}

function deleteEkskul() {
  const sched = getSchedule();
  if (sched[st.day]) sched[st.day].ekskul = null;
  setSchedule(sched);
  renderPanel();
  renderSchedule();
  toast('Ekskul dihapus');
}

function switchDetail(view) {
  st.detailView = view;
  document.getElementById('navTugas').classList.toggle('active', view === 'tugas');
  document.getElementById('navCatatan').classList.toggle('active', view === 'catatan');
  if (view === 'tugas') renderTugas();
  else renderCatatan();
}

function renderTugas() {
  const tasks = getTasks();
  const list = tasks[st.subjectId] || [];
  const now = new Date(); now.setHours(0,0,0,0);
  const tom = new Date(now); tom.setDate(tom.getDate()+1);

  let html = `<div class="sec-header">
    <div>
      <div class="sec-title">Tugas</div>
      <div class="sec-sub">${list.length} tugas</div>
    </div>
    <button class="btn btn-primary" onclick="openTaskModal()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Tugas
    </button>
  </div>`;

  if (!list.length) {
    html += emptyState('M9 11l3 3L22 4 M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11','Belum ada tugas<br>Tambah tugas untuk mapel ini');
  } else {
    const EDIT_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
    const DEL_ICON  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;

    list.forEach(t => {
      let badge = '';
      if (t.deadline) {
        const dl = new Date(t.deadline); dl.setHours(0,0,0,0);
        if (dl < now)                     badge = '<span class="badge badge-danger">Overdue</span>';
        else if (dl.getTime()===now.getTime()) badge = '<span class="badge badge-warn">Hari ini</span>';
        else if (dl.getTime()===tom.getTime()) badge = '<span class="badge badge-warn">Besok</span>';
        else                              badge = '<span class="badge badge-ok">Tepat waktu</span>';
      }
      html += `<div class="task-card">
        <div class="task-info">
          <div class="task-nama">${esc(t.nama)}</div>
          <div class="task-deadline">${t.deadline ? fmtDate(t.deadline) : 'Tanpa deadline'}</div>
        </div>
        <div class="task-right">
          ${badge}
          <button class="action-btn action-edit" onclick="openTaskModal('${t.id}')" title="Edit">${EDIT_ICON}</button>
          <button class="action-btn action-delete" onclick="deleteTask('${t.id}')" title="Hapus">${DEL_ICON}</button>
        </div>
      </div>`;
    });
  }

  document.getElementById('detailContent').innerHTML = html;
}

function fmtDate(str) {
  if (!str) return '';
  return new Date(str).toLocaleDateString('id-ID', { weekday:'short', day:'numeric', month:'short', year:'numeric' });
}

function openTaskModal(editId) {
  st.editTaskId = editId || null;
  document.getElementById('taskModalTitle').textContent = editId ? 'Edit Tugas' : 'Tambah Tugas';
  if (editId) {
    const t = (getTasks()[st.subjectId] || []).find(x => x.id === editId);
    if (t) { document.getElementById('tNama').value = t.nama; document.getElementById('tDeadline').value = t.deadline||''; }
  } else {
    document.getElementById('tNama').value = '';
    document.getElementById('tDeadline').value = '';
  }
  openModal('taskModal');
}

function saveTask() {
  const nama = document.getElementById('tNama').value.trim();
  const deadline = document.getElementById('tDeadline').value;
  if (!nama) { toast('Nama tugas wajib diisi'); return; }

  const tasks = getTasks();
  if (!tasks[st.subjectId]) tasks[st.subjectId] = [];
  if (st.editTaskId) {
    tasks[st.subjectId] = tasks[st.subjectId].map(t => t.id===st.editTaskId ? {...t, nama, deadline} : t);
    toast('Tugas diperbarui');
  } else {
    tasks[st.subjectId].push({ id:uid(), nama, deadline });
    toast('Tugas ditambahkan');
  }
  setTasks(tasks);
  closeModal('taskModal');
  renderTugas();
  st.editTaskId = null;
}

function deleteTask(id) {
  if (!confirm('Hapus tugas ini?')) return;
  const tasks = getTasks();
  tasks[st.subjectId] = (tasks[st.subjectId]||[]).filter(t => t.id !== id);
  setTasks(tasks);
  renderTugas();
  toast('Tugas dihapus');
}

function renderCatatan() {
  const notes = getNotes();
  const list = notes[st.subjectId] || [];

  const EDIT_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
  const DEL_ICON  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;
  const DL_ICON   = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`;
  const DOC_ICON  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`;

  let html = `<div class="sec-header">
    <div>
      <div class="sec-title">Catatan</div>
      <div class="sec-sub">${list.length} catatan</div>
    </div>
    <button class="btn btn-primary" onclick="openNoteModal()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Tambah Catatan
    </button>
  </div>`;

  if (!list.length) {
    html += emptyState('M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2L14 8 20 8','Belum ada catatan<br>Tambah catatan untuk mapel ini');
  } else {
    list.forEach(n => {
      const filesHtml = (n.files||[]).map(f => {
        const isImg = f.type && f.type.startsWith('image/');
        return `<div class="file-row">
          ${isImg
            ? `<img src="${f.data}" alt="${esc(f.name)}">`
            : `<div class="file-icon">${DOC_ICON}</div>`}
          <span class="file-name">${esc(f.name)}</span>
          <button class="btn btn-ghost btn-sm" onclick="dlFile('${n.id}','${f.id}')" title="Unduh">${DL_ICON}</button>
          <button class="action-btn action-delete" onclick="rmNoteFile('${n.id}','${f.id}')" title="Hapus file">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>`;
      }).join('');

      html += `<div class="note-card">
        <div class="note-card-header">
          <div class="note-judul">${esc(n.judul)}</div>
          <div class="note-card-actions">
            <button class="action-btn action-edit" onclick="openNoteModal('${n.id}')" title="Edit">${EDIT_ICON}</button>
            <button class="action-btn action-delete" onclick="deleteNote('${n.id}')" title="Hapus">${DEL_ICON}</button>
          </div>
        </div>
        <div class="note-isi">${esc(n.isi)}</div>
        ${filesHtml ? `<div class="note-files">${filesHtml}</div>` : ''}
      </div>`;
    });
  }

  document.getElementById('detailContent').innerHTML = html;
}

function dlFile(noteId, fileId) {
  const n = (getNotes()[st.subjectId]||[]).find(x => x.id===noteId);
  if (!n) return;
  const f = (n.files||[]).find(x => x.id===fileId);
  if (!f) return;
  const a = document.createElement('a');
  a.href = f.data; a.download = f.name; a.click();
}

function rmNoteFile(noteId, fileId) {
  const notes = getNotes();
  const list = notes[st.subjectId] || [];
  const idx = list.findIndex(n => n.id===noteId);
  if (idx === -1) return;
  list[idx].files = (list[idx].files||[]).filter(f => f.id!==fileId);
  setNotes(notes);
  renderCatatan();
  toast('File dihapus');
}

function openNoteModal(editId) {
  st.editNoteId = editId || null;
  pendingFiles = [];
  document.getElementById('noteModalTitle').textContent = editId ? 'Edit Catatan' : 'Tambah Catatan';
  if (editId) {
    const n = (getNotes()[st.subjectId]||[]).find(x => x.id===editId);
    if (n) {
      document.getElementById('nJudul').value = n.judul;
      document.getElementById('nIsi').value = n.isi;
      pendingFiles = (n.files||[]).map(f => ({...f}));
    }
  } else {
    document.getElementById('nJudul').value = '';
    document.getElementById('nIsi').value = '';
  }
  renderPendingFiles();
  openModal('noteModal');
}

function handleFiles(e) {
  Array.from(e.target.files).forEach(file => {
    if (file.size > 3 * 1024 * 1024) { toast(`${file.name}: melebihi batas 3 MB!`); return; }
    const reader = new FileReader();
    reader.onload = ev => {
      pendingFiles.push({ id:uid(), name:file.name, type:file.type, data:ev.target.result });
      renderPendingFiles();
    };
    reader.readAsDataURL(file);
  });
  e.target.value = '';
}

function renderPendingFiles() {
  document.getElementById('pendingFiles').innerHTML = pendingFiles.map(f => `
    <div class="pending-item">
      ${f.type&&f.type.startsWith('image/') ? `<img class="thumb" src="${f.data}" alt="">` : `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;flex-shrink:0;color:var(--text-muted)"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`}
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${esc(f.name)}</span>
      <button class="remove" onclick="removePending('${f.id}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:11px;height:11px"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>`).join('');
}

function removePending(id) {
  pendingFiles = pendingFiles.filter(f => f.id!==id);
  renderPendingFiles();
}

function saveNote() {
  const judul = document.getElementById('nJudul').value.trim();
  const isi   = document.getElementById('nIsi').value.trim();
  if (!judul) { toast('Judul catatan wajib diisi'); return; }

  const notes = getNotes();
  if (!notes[st.subjectId]) notes[st.subjectId] = [];
  if (st.editNoteId) {
    notes[st.subjectId] = notes[st.subjectId].map(n =>
      n.id===st.editNoteId ? {...n, judul, isi, files:[...pendingFiles]} : n
    );
    toast('Catatan diperbarui');
  } else {
    notes[st.subjectId].push({ id:uid(), judul, isi, files:[...pendingFiles] });
    toast('Catatan ditambahkan');
  }
  setNotes(notes);
  closeModal('noteModal');
  renderCatatan();
  st.editNoteId = null;
}

function deleteNote(id) {
  if (!confirm('Hapus catatan ini?')) return;
  const notes = getNotes();
  notes[st.subjectId] = (notes[st.subjectId]||[]).filter(n => n.id!==id);
  setNotes(notes);
  renderCatatan();
  toast('Catatan dihapus');
}

function renderSN() {
  const list = getSN();
  const EDIT_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`;
  const DEL_ICON  = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>`;

  if (!list.length) {
    document.getElementById('snGrid').innerHTML = `<div class="empty" style="grid-column:1/-1">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      <p>Belum ada catatan khusus<br>Tambah catatan untuk mulai</p>
    </div>`;
    return;
  }

  document.getElementById('snGrid').innerHTML = list.map(n => `
    <div class="note-card">
      <div class="note-card-header">
        <div class="note-judul">${esc(n.judul)}</div>
        <div class="note-card-actions">
          <button class="action-btn action-edit" onclick="openSpecialNoteModal('${n.id}')" title="Edit">${EDIT_ICON}</button>
          <button class="action-btn action-delete" onclick="deleteSN('${n.id}')" title="Hapus">${DEL_ICON}</button>
        </div>
      </div>
      <div class="note-isi">${esc(n.isi)}</div>
      ${n.updatedAt ? `<div style="font-size:11px;color:var(--text-muted);margin-top:10px">${new Date(n.updatedAt).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'})}</div>` : ''}
    </div>`).join('');
}

function openSpecialNoteModal(editId) {
  st.editSnId = editId || null;
  document.getElementById('snModalTitle').textContent = editId ? 'Edit Catatan' : 'Tambah Catatan Khusus';
  if (editId) {
    const n = getSN().find(x => x.id===editId);
    if (n) { document.getElementById('snJudul').value = n.judul; document.getElementById('snIsi').value = n.isi; }
  } else {
    document.getElementById('snJudul').value = '';
    document.getElementById('snIsi').value = '';
  }
  openModal('snModal');
}

function saveSpecialNote() {
  const judul = document.getElementById('snJudul').value.trim();
  const isi   = document.getElementById('snIsi').value.trim();
  if (!judul) { toast('Judul catatan wajib diisi'); return; }
  const list = getSN();
  if (st.editSnId) {
    const idx = list.findIndex(n => n.id===st.editSnId);
    if (idx!==-1) list[idx] = {...list[idx], judul, isi, updatedAt:new Date().toISOString()};
    toast('Catatan diperbarui');
  } else {
    list.unshift({ id:uid(), judul, isi, updatedAt:new Date().toISOString() });
    toast('Catatan ditambahkan');
  }
  setSN(list);
  closeModal('snModal');
  renderSN();
  st.editSnId = null;
}

function deleteSN(id) {
  if (!confirm('Hapus catatan ini?')) return;
  setSN(getSN().filter(n => n.id!==id));
  renderSN();
  toast('Catatan dihapus');
}

function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target===o) o.classList.remove('open'); });
});
document.getElementById('panelOverlay').addEventListener('click', e => {
  if (e.target===document.getElementById('panelOverlay')) closePanel();
});

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
}

function toast(msg) {
  const w = document.getElementById('toastWrap');
  const t = document.createElement('div');
  t.className = 'toast';
  t.textContent = msg;
  w.appendChild(t);
  setTimeout(() => {
    t.style.cssText = 'opacity:0;transform:translateY(8px);transition:all .2s';
    setTimeout(() => t.remove(), 200);
  }, 2600);
}

function emptyState(pathD, txt) {
  return `<div class="empty">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="${pathD.split(' ').join(' ')}"/>
    </svg>
    <p>${txt}</p>
  </div>`;
}

if ("serviceWorker" in navigator) {
  navigator.serviceWorker.register("service-worker.js");
   .then(() => console.log("SW registered"))
   .catch(err => console.log(err));
}

renderSchedule();
</script>
