          <p></p>
        </div>
        <input type="file" id="fileInput" style="display:none" multiple accept=".jpg,.jpeg,.png,.pdf,.doc,.docx" onchange="handleFiles(event)">
        <div class="pending-files" id="pendingFiles"></div>
